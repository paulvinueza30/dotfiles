{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@slkiser/opencode-quota"],
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "allWindows",
      "percentDisplayMode": "remaining"
    }
  },
  "mcp": {
    "n8n-mcp": {
      "type": "remote",
      "url": "https://api.n8n-mcp.com/mcp",
      "enabled": true
    }
  }
}
